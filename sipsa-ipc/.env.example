# Variables de entorno para la API SIPSA IPC
# Copiar a .env y ajustar valores antes de ejecutar en producción.

# Clave de autenticación para todos los endpoints (header X-API-Key)
# En desarrollo se usa "dev-key-sipsa" por defecto (NO usar en producción)
SIPSA_API_KEY=dev-key-sipsa

# Límite de peticiones por IP (formato slowapi: "N/periodo")
# Ejemplos: "60/minute", "1000/hour", "10000/day"
SIPSA_RATE_LIMIT=60/minute
